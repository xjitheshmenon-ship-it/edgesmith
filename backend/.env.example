# CPCMS backend (Node.js) environment
NODE_ENV=development
PORT=8000
DATABASE_URL=postgresql://edgesmith:edgesmith@localhost:5432/edgesmith
# Long random secret in production: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:3000
# Shift start times (used by background jobs)
SHIFT_1_START=06:00
SHIFT_2_START=14:00
SHIFT_3_START=22:00
